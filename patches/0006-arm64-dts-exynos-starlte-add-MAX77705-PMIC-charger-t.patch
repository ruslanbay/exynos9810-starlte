From 34ee85b8e1c499ecf41d746930f8ffb1fe75f319 Mon Sep 17 00:00:00 2001
From: Ruslan Bay <ruslanbey@proton.me>
Date: Mon, 9 Mar 2026 23:18:54 +0100
Subject: [PATCH 06/28] arm64: dts: exynos: starlte: add MAX77705 PMIC/charger
 topology

---
 .../boot/dts/exynos/exynos9810-starlte.dts    | 40 +++++++++++++++++++
 1 file changed, 40 insertions(+)

diff --git a/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts b/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
index 8fe1fd3f1..d63192910 100644
--- a/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
+++ b/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
@@ -10,6 +10,7 @@
 #include "exynos9810.dtsi"
 #include <dt-bindings/gpio/gpio.h>
 #include <dt-bindings/input/input.h>
+#include <dt-bindings/interrupt-controller/irq.h>
 
 / {
 	model = "Samsung Galaxy S9 (SM-G960F)";
@@ -82,6 +83,14 @@ framebuffer@cc000000 {
 			no-map;
 		};
 	};
+
+	battery: battery {
+		compatible = "simple-battery";
+		constant-charge-current-max-microamp = <2150000>;
+		charge-full-design-microamp-hours = <3000000>;
+		voltage-min-design-microvolt = <3400000>;
+		voltage-max-design-microvolt = <4350000>;
+	};
 };
 
 &oscclk {
@@ -134,6 +143,37 @@ s2dos05_buck: buck {
 	};
 };
 
+&hsi2c_44 {
+	#address-cells = <1>;
+	#size-cells = <0>;
+	status = "okay";
+
+	max77705: pmic@66 {
+		compatible = "maxim,max77705";
+		reg = <0x66>;
+		interrupt-controller;
+		#interrupt-cells = <1>;
+		interrupt-parent = <&gpa1>;
+		interrupts = <2 IRQ_TYPE_LEVEL_LOW>;
+	};
+
+	max77705_charger: charger@69 {
+		compatible = "maxim,max77705-charger";
+		reg = <0x69>;
+		monitored-battery = <&battery>;
+		interrupt-parent = <&max77705>;
+		interrupts = <0>;
+	};
+
+	fuel-gauge@36 {
+		compatible = "maxim,max77705-battery";
+		reg = <0x36>;
+		power-supplies = <&max77705_charger>;
+		interrupt-parent = <&max77705>;
+		interrupts = <2>;
+	};
+};
+
 &pinctrl_alive {
 	key_power: key-power-pins {
 		samsung,pins = "gpa2-4";
-- 
2.53.0

