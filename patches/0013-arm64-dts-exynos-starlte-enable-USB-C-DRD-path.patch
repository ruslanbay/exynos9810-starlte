From 19da26f3f3f522f5d80650747a754a0d7199465f Mon Sep 17 00:00:00 2001
From: Ruslan Bay <ruslanbey@proton.me>
Date: Mon, 9 Mar 2026 23:18:57 +0100
Subject: [PATCH 13/28] arm64: dts: exynos: starlte: enable USB-C DRD path

---
 .../boot/dts/exynos/exynos9810-starlte.dts    | 22 +++++++++++++++++++
 1 file changed, 22 insertions(+)

diff --git a/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts b/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
index 302a783a3..b6206f15c 100644
--- a/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
+++ b/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
@@ -11,6 +11,7 @@
 #include <dt-bindings/gpio/gpio.h>
 #include <dt-bindings/input/input.h>
 #include <dt-bindings/interrupt-controller/irq.h>
+#include <dt-bindings/usb/pd.h>
 
 / {
 	model = "Samsung Galaxy S9 (SM-G960F)";
@@ -216,6 +217,27 @@ &mmc {
 	status = "okay";
 };
 
+&usbdrd {
+	vdd10-supply = <&s2dos05_buck>;
+	vdd33-supply = <&s2dos05_ldo3>;
+	status = "okay";
+};
+
+&usbdrd_dwc3 {
+	status = "okay";
+	dr_mode = "otg";
+	#address-cells = <1>;
+	#size-cells = <0>;
+
+	connector {
+		compatible = "usb-c-connector";
+		label = "USB-C";
+		data-role = "device";
+		power-role = "sink";
+		status = "disabled";
+	};
+};
+
 &pinctrl_alive {
 	key_power: key-power-pins {
 		samsung,pins = "gpa2-4";
-- 
2.53.0

