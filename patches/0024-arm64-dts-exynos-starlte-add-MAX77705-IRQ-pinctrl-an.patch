From deac38cf1a94a1e61a0e32279ca259acc1f2b7a5 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Wed, 11 Mar 2026 13:05:07 +0000
Subject: [PATCH 24/27] arm64: dts: exynos: starlte: add MAX77705 IRQ pinctrl
 and wakeup-source

---
 arch/arm64/boot/dts/exynos/exynos9810-starlte.dts | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts b/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
index 6813bbe535f1..414c2c73e26c 100644
--- a/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
+++ b/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
@@ -250,6 +250,9 @@ max77705: pmic@66 {
 		#interrupt-cells = <1>;
 		interrupt-parent = <&gpa1>;
 		interrupts = <2 IRQ_TYPE_LEVEL_LOW>;
+		wakeup-source;
+		pinctrl-0 = <&max77705_irq>;
+		pinctrl-names = "default";
 	};
 
 	max77705_charger: charger@69 {
