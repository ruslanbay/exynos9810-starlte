From c30b2fa235113e1dc4e1a05fac09d8e8120304a9 Mon Sep 17 00:00:00 2001
From: Ruslan Bay <ruslanbey@proton.me>
Date: Mon, 9 Mar 2026 23:18:55 +0100
Subject: [PATCH 10/28] arm64: dts: exynos: add Exynos9810 dw-mshc node

---
 arch/arm64/boot/dts/exynos/exynos9810.dtsi | 11 +++++++++++
 1 file changed, 11 insertions(+)

diff --git a/arch/arm64/boot/dts/exynos/exynos9810.dtsi b/arch/arm64/boot/dts/exynos/exynos9810.dtsi
index bba20a2bc..5f232c1ed 100644
--- a/arch/arm64/boot/dts/exynos/exynos9810.dtsi
+++ b/arch/arm64/boot/dts/exynos/exynos9810.dtsi
@@ -509,6 +509,17 @@ ufs_phy: phy@11124000 {
 			#phy-cells = <0>;
 			status = "disabled";
 		};
+
+		mmc: mmc@11500000 {
+			compatible = "samsung,exynos7-dw-mshc";
+			reg = <0x11500000 0x2000>;
+			interrupts = <GIC_SPI 249 IRQ_TYPE_LEVEL_HIGH>;
+			clocks = <&oscclk>, <&oscclk>;
+			clock-names = "biu", "ciu";
+			#address-cells = <1>;
+			#size-cells = <0>;
+			status = "disabled";
+		};
 	};
 
 	timer {
-- 
2.53.0

