From b87feb88ad472d1218c993971119d37f745a56b4 Mon Sep 17 00:00:00 2001
From: Ruslan Bay <ruslanbey@proton.me>
Date: Mon, 9 Mar 2026 23:18:55 +0100
Subject: [PATCH 10/27] arm64: dts: exynos: add Exynos9810 dw-mshc node

---
 arch/arm64/boot/dts/exynos/exynos9810.dtsi | 9 +++++++++
 1 file changed, 9 insertions(+)

diff --git a/arch/arm64/boot/dts/exynos/exynos9810.dtsi b/arch/arm64/boot/dts/exynos/exynos9810.dtsi
index cf34da1bbf22..827234a049ca 100644
--- a/arch/arm64/boot/dts/exynos/exynos9810.dtsi
+++ b/arch/arm64/boot/dts/exynos/exynos9810.dtsi
@@ -479,6 +479,15 @@ ufs_phy: phy@11124000 {
 			#phy-cells = <0>;
 			status = "disabled";
 		};
+
+		mmc: mmc@11500000 {
+			compatible = "samsung,exynos-dw-mshc";
+			reg = <0x11500000 0x2000>;
+			interrupts = <GIC_SPI 249 IRQ_TYPE_LEVEL_HIGH>;
+			#address-cells = <1>;
+			#size-cells = <0>;
+			status = "disabled";
+		};
 	};
 
 	timer {
-- 
2.53.0

