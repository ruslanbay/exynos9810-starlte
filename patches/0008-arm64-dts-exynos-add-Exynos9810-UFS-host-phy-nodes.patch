From 48c3c8a81cc8eeec38fb16bfa2105bfd06c22503 Mon Sep 17 00:00:00 2001
From: Ruslan Bay <ruslanbey@proton.me>
Date: Mon, 9 Mar 2026 23:18:54 +0100
Subject: [PATCH 08/27] arm64: dts: exynos: add Exynos9810 UFS host/phy nodes

---
 arch/arm64/boot/dts/exynos/exynos9810.dtsi | 19 +++++++++++++++++++
 1 file changed, 19 insertions(+)

diff --git a/arch/arm64/boot/dts/exynos/exynos9810.dtsi b/arch/arm64/boot/dts/exynos/exynos9810.dtsi
index 943003e851e2..cf34da1bbf22 100644
--- a/arch/arm64/boot/dts/exynos/exynos9810.dtsi
+++ b/arch/arm64/boot/dts/exynos/exynos9810.dtsi
@@ -460,6 +460,25 @@ watchdog_cl1: watchdog@10060000 {
 			samsung,syscon-phandle = <&pmu_system_controller>;
 			status = "disabled";
 		};
+
+		ufs: ufs@11120000 {
+			compatible = "samsung,exynos-ufs";
+			reg = <0x11120000 0x200>,
+			      <0x11121100 0x200>,
+			      <0x11110000 0x8000>,
+			      <0x11130000 0x100>;
+			interrupts = <GIC_SPI 242 IRQ_TYPE_LEVEL_HIGH>;
+			pinctrl-names = "default";
+			pinctrl-0 = <&ufs_rst_n &ufs_refclk_out>;
+			status = "disabled";
+		};
+
+		ufs_phy: phy@11124000 {
+			compatible = "samsung,exynos7-ufs-phy";
+			reg = <0x11124000 0x800>;
+			#phy-cells = <0>;
+			status = "disabled";
+		};
 	};
 
 	timer {
-- 
2.53.0

