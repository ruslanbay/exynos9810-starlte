From a812693c3f7933dcd8d3a6964c70978822bb201c Mon Sep 17 00:00:00 2001
From: Ruslan Bay <ruslanbey@proton.me>
Date: Mon, 9 Mar 2026 23:18:54 +0100
Subject: [PATCH 08/28] arm64: dts: exynos: add Exynos9810 UFS host/phy nodes

---
 arch/arm64/boot/dts/exynos/exynos9810.dtsi | 29 ++++++++++++++++++++++
 1 file changed, 29 insertions(+)

diff --git a/arch/arm64/boot/dts/exynos/exynos9810.dtsi b/arch/arm64/boot/dts/exynos/exynos9810.dtsi
index 2e9c9989e..bba20a2bc 100644
--- a/arch/arm64/boot/dts/exynos/exynos9810.dtsi
+++ b/arch/arm64/boot/dts/exynos/exynos9810.dtsi
@@ -480,6 +480,35 @@ watchdog_cl1: watchdog@10060000 {
 			samsung,syscon-phandle = <&pmu_system_controller>;
 			status = "disabled";
 		};
+
+		ufs: ufs@11120000 {
+			compatible = "samsung,exynos7-ufs";
+			reg = <0x11120000 0x200>,
+			      <0x11121100 0x200>,
+			      <0x11110000 0x8000>,
+			      <0x11130000 0x100>;
+			interrupts = <GIC_SPI 242 IRQ_TYPE_LEVEL_HIGH>;
+			phys = <&ufs_phy>;
+			phy-names = "ufs-phy";
+			clocks = <&oscclk>, <&oscclk>;
+			clock-names = "core_clk", "sclk_unipro_main";
+			pinctrl-names = "default";
+			pinctrl-0 = <&ufs_rst_n &ufs_refclk_out>;
+			status = "disabled";
+		};
+
+		ufs_phy: phy@11124000 {
+			compatible = "samsung,exynos7-ufs-phy";
+			reg = <0x11124000 0x800>;
+			reg-names = "phy-pma";
+			clocks = <&oscclk>, <&oscclk>, <&oscclk>,
+				 <&oscclk>;
+			clock-names = "ref_clk", "rx1_symbol_clk",
+				      "rx0_symbol_clk", "tx0_symbol_clk";
+			samsung,pmu-syscon = <&pmu_system_controller>;
+			#phy-cells = <0>;
+			status = "disabled";
+		};
 	};
 
 	timer {
-- 
2.53.0

