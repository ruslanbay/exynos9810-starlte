From 1be0b097f71eda2d8f051d56797f110cb2b35178 Mon Sep 17 00:00:00 2001
From: Ruslan Bay <ruslanbey@proton.me>
Date: Mon, 9 Mar 2026 23:18:57 +0100
Subject: [PATCH 14/27] arm64: dts: exynos: add Exynos9810 display host nodes

---
 arch/arm64/boot/dts/exynos/exynos9810.dtsi | 22 ++++++++++++++++++++++
 1 file changed, 22 insertions(+)

diff --git a/arch/arm64/boot/dts/exynos/exynos9810.dtsi b/arch/arm64/boot/dts/exynos/exynos9810.dtsi
index 331b39c1fc4e..7105376502b8 100644
--- a/arch/arm64/boot/dts/exynos/exynos9810.dtsi
+++ b/arch/arm64/boot/dts/exynos/exynos9810.dtsi
@@ -516,6 +516,28 @@ usbdrd_phy: phy@11100000 {
 			#phy-cells = <1>;
 			status = "disabled";
 		};
+
+		decon_f: display-controller@16030000 {
+			compatible = "samsung,exynos9-decon";
+			reg = <0x16030000 0x10000>;
+			interrupts = <GIC_SPI 194 IRQ_TYPE_LEVEL_HIGH>;
+			status = "disabled";
+		};
+
+		dsim0: dsi@16080000 {
+			compatible = "samsung,exynos9-dsim";
+			reg = <0x16080000 0x10000>;
+			interrupts = <GIC_SPI 203 IRQ_TYPE_LEVEL_HIGH>;
+			#address-cells = <1>;
+			#size-cells = <0>;
+			status = "disabled";
+
+			port {
+				dsim0_out: endpoint {
+					remote-endpoint = <&panel_in>;
+				};
+			};
+		};
 	};
 
 	timer {
-- 
2.53.0

