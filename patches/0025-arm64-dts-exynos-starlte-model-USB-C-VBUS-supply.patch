From 40ee234718fead2b05c20b73efd0a9d17726037a Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Wed, 11 Mar 2026 13:08:49 +0000
Subject: [PATCH 25/27] arm64: dts: exynos: starlte: model USB-C VBUS supply

---
 arch/arm64/boot/dts/exynos/exynos9810-starlte.dts | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts b/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
index 414c2c73e26c..051864692728 100644
--- a/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
+++ b/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
@@ -124,6 +124,13 @@ ufs_vcc_reg: regulator-1 {
 		gpio = <&gpf0 2 GPIO_ACTIVE_HIGH>;
 	};
 
+	usb_vbus_reg: regulator-2 {
+		compatible = "regulator-fixed";
+		regulator-name = "usb-vbus";
+		regulator-min-microvolt = <5000000>;
+		regulator-max-microvolt = <5000000>;
+	};
+
 	battery: battery {
 		compatible = "simple-battery";
 		constant-charge-current-max-microamp = <2150000>;
@@ -343,6 +350,7 @@ connector {
 		label = "USB-C";
 		data-role = "device";
 		power-role = "sink";
+		vbus-supply = <&usb_vbus_reg>;
 		status = "disabled";
 	};
 };
-- 
