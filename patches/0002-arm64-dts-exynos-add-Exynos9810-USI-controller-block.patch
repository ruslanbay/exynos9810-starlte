From fdb10ee94d36acdfc0a05abd41b97b36ab6ad983 Mon Sep 17 00:00:00 2001
From: Ruslan Bay <ruslanbey@proton.me>
Date: Mon, 9 Mar 2026 23:18:52 +0100
Subject: [PATCH 02/28] arm64: dts: exynos: add Exynos9810 USI controller
 blocks

---
 arch/arm64/boot/dts/exynos/exynos9810.dtsi | 126 +++++++++++++++++++++
 1 file changed, 126 insertions(+)

diff --git a/arch/arm64/boot/dts/exynos/exynos9810.dtsi b/arch/arm64/boot/dts/exynos/exynos9810.dtsi
index 4eadf508d..ea59193e8 100644
--- a/arch/arm64/boot/dts/exynos/exynos9810.dtsi
+++ b/arch/arm64/boot/dts/exynos/exynos9810.dtsi
@@ -7,6 +7,7 @@
  */
 
 #include <dt-bindings/interrupt-controller/arm-gic.h>
+#include <dt-bindings/soc/samsung,exynos-usi.h>
 
 / {
 	compatible = "samsung,exynos9810";
@@ -303,6 +304,131 @@ pinctrl_aud: pinctrl@17c60000 {
 			compatible = "samsung,exynos9810-pinctrl";
 			reg = <0x17c60000 0x1000>;
 		};
+
+		usi_hsi2c_10: usi@104b00c0 {
+			compatible = "samsung,exynos850-usi";
+			reg = <0x104b00c0 0x20>;
+			samsung,sysreg = <&syscon_peric0 0x1000>;
+			clocks = <&cmu_peric0 0xcd>, <&cmu_peric0 0xe0>;
+			clock-names = "pclk", "ipclk";
+			samsung,mode = <USI_MODE_I2C>;
+			#address-cells = <1>;
+			#size-cells = <1>;
+			ranges;
+			status = "disabled";
+
+			hsi2c_10: i2c@104b0000 {
+				compatible = "samsung,exynos850-hsi2c",
+					     "samsung,exynosautov9-hsi2c";
+				reg = <0x104b0000 0xc0>;
+				interrupts = <GIC_SPI 404 IRQ_TYPE_LEVEL_HIGH>;
+				clocks = <&cmu_peric0 0xe0>, <&cmu_peric0 0xcd>;
+				clock-names = "hsi2c", "hsi2c_pclk";
+				#address-cells = <1>;
+				#size-cells = <0>;
+				status = "disabled";
+			};
+		};
+
+		usi_hsi2c_11: usi@108e00c0 {
+			compatible = "samsung,exynos850-usi";
+			reg = <0x108e00c0 0x20>;
+			samsung,sysreg = <&syscon_peric1 0x1000>;
+			clocks = <&cmu_peric1 0xfc>, <&cmu_peric1 0x114>;
+			clock-names = "pclk", "ipclk";
+			samsung,mode = <USI_MODE_I2C>;
+			#address-cells = <1>;
+			#size-cells = <1>;
+			ranges;
+			status = "disabled";
+
+			hsi2c_11: i2c@108e0000 {
+				compatible = "samsung,exynos850-hsi2c",
+					     "samsung,exynosautov9-hsi2c";
+				reg = <0x108e0000 0xc0>;
+				interrupts = <GIC_SPI 432 IRQ_TYPE_LEVEL_HIGH>;
+				clocks = <&cmu_peric1 0x114>, <&cmu_peric1 0xfc>;
+				clock-names = "hsi2c", "hsi2c_pclk";
+				#address-cells = <1>;
+				#size-cells = <0>;
+				status = "disabled";
+			};
+		};
+
+		usi_hsi2c_12: usi@109000c0 {
+			compatible = "samsung,exynos850-usi";
+			reg = <0x109000c0 0x20>;
+			samsung,sysreg = <&syscon_peric1 0x1004>;
+			clocks = <&cmu_peric1 0xfd>, <&cmu_peric1 0x115>;
+			clock-names = "pclk", "ipclk";
+			samsung,mode = <USI_MODE_I2C>;
+			#address-cells = <1>;
+			#size-cells = <1>;
+			ranges;
+			status = "disabled";
+
+			hsi2c_12: i2c@10900000 {
+				compatible = "samsung,exynos850-hsi2c",
+					     "samsung,exynosautov9-hsi2c";
+				reg = <0x10900000 0xc0>;
+				interrupts = <GIC_SPI 414 IRQ_TYPE_LEVEL_HIGH>;
+				clocks = <&cmu_peric1 0x115>, <&cmu_peric1 0xfd>;
+				clock-names = "hsi2c", "hsi2c_pclk";
+				#address-cells = <1>;
+				#size-cells = <0>;
+				status = "disabled";
+			};
+		};
+
+		usi_hsi2c_43: usi@143500c0 {
+			compatible = "samsung,exynos850-usi";
+			reg = <0x143500c0 0x20>;
+			samsung,sysreg = <&syscon_fsys1 0x1000>;
+			clocks = <&cmu_fsys1 0x69>, <&cmu_fsys1 0x5f>;
+			clock-names = "pclk", "ipclk";
+			samsung,mode = <USI_MODE_I2C>;
+			#address-cells = <1>;
+			#size-cells = <1>;
+			ranges;
+			status = "disabled";
+
+			hsi2c_43: i2c@14350000 {
+				compatible = "samsung,exynos850-hsi2c",
+					     "samsung,exynosautov9-hsi2c";
+				reg = <0x14350000 0xc0>;
+				interrupts = <GIC_SPI 5 IRQ_TYPE_LEVEL_HIGH>;
+				clocks = <&cmu_fsys1 0x5f>, <&cmu_fsys1 0x69>;
+				clock-names = "hsi2c", "hsi2c_pclk";
+				#address-cells = <1>;
+				#size-cells = <0>;
+				status = "disabled";
+			};
+		};
+
+		usi_hsi2c_44: usi@143600c0 {
+			compatible = "samsung,exynos850-usi";
+			reg = <0x143600c0 0x20>;
+			samsung,sysreg = <&syscon_fsys1 0x1004>;
+			clocks = <&cmu_fsys1 0x6e>, <&cmu_fsys1 0x72>;
+			clock-names = "pclk", "ipclk";
+			samsung,mode = <USI_MODE_I2C>;
+			#address-cells = <1>;
+			#size-cells = <1>;
+			ranges;
+			status = "disabled";
+
+			hsi2c_44: i2c@14360000 {
+				compatible = "samsung,exynos850-hsi2c",
+					     "samsung,exynosautov9-hsi2c";
+				reg = <0x14360000 0xc0>;
+				interrupts = <GIC_SPI 6 IRQ_TYPE_LEVEL_HIGH>;
+				clocks = <&cmu_fsys1 0x72>, <&cmu_fsys1 0x6e>;
+				clock-names = "hsi2c", "hsi2c_pclk";
+				#address-cells = <1>;
+				#size-cells = <0>;
+				status = "disabled";
+			};
+		};
 	};
 
 	timer {
-- 
2.53.0

