From 4e9def3dfda994b712a8f5dd41bc641a6b5fdd64 Mon Sep 17 00:00:00 2001
From: Ruslan Bay <ruslanbey@proton.me>
Date: Mon, 9 Mar 2026 23:18:58 +0100
Subject: [PATCH 16/27] arm64: dts: exynos: starlte: add S6SY761 touchscreen
 node

---
 .../boot/dts/exynos/exynos9810-starlte.dts    | 30 +++++++++++++++++++
 1 file changed, 30 insertions(+)

diff --git a/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts b/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
index 764a5b5bf1d8..ec22a5f374e5 100644
--- a/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
+++ b/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
@@ -112,6 +112,8 @@ &oscclk {
 &hsi2c_43 {
 	#address-cells = <1>;
 	#size-cells = <0>;
+	pinctrl-0 = <&hsi2c43_bus>;
+	pinctrl-names = "default";
 	status = "okay";
 
 	s2dos05_pmic: pmic@60 {
@@ -154,9 +156,30 @@ s2dos05_buck: buck {
 	};
 };
 
+&hsi2c_10 {
+	#address-cells = <1>;
+	#size-cells = <0>;
+	pinctrl-0 = <&hsi2c10_bus>;
+	pinctrl-names = "default";
+	status = "okay";
+
+	touchscreen@48 {
+		compatible = "samsung,s6sy761";
+		reg = <0x48>;
+		pinctrl-0 = <&ts_int>;
+		pinctrl-names = "default";
+		interrupt-parent = <&gpa1>;
+		interrupts = <0 IRQ_TYPE_LEVEL_LOW>;
+		avdd-supply = <&s2dos05_ldo3>;
+		vdd-supply = <&s2dos05_ldo2>;
+	};
+};
+
 &hsi2c_44 {
 	#address-cells = <1>;
 	#size-cells = <0>;
+	pinctrl-0 = <&hsi2c44_bus>;
+	pinctrl-names = "default";
 	status = "okay";
 
 	max77705: pmic@66 {
@@ -297,6 +320,13 @@ sd2_cd: sd2-cd-pins {
 		samsung,pin-pud = <EXYNOS_PIN_PULL_UP>;
 		samsung,pin-drv = <EXYNOS7_PIN_DRV_LV4>;
 	};
+
+	ts_int: ts-int-pins {
+		samsung,pins = "gpa1-0";
+		samsung,pin-function = <EXYNOS_PIN_FUNC_EINT>;
+		samsung,pin-pud = <EXYNOS_PIN_PULL_NONE>;
+		samsung,pin-drv = <EXYNOS7_PIN_DRV_LV1>;
+	};
 };
 
 &pinctrl_fsys1 {
-- 
2.53.0

