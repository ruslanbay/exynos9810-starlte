From 20a6792c8080b722859f8dc03e0cee1f2e8ef9db Mon Sep 17 00:00:00 2001
From: Ruslan Bay <ruslanbey@proton.me>
Date: Mon, 9 Mar 2026 23:18:58 +0100
Subject: [PATCH 17/27] arm64: dts: exynos: starlte: add ramoops and tighten
 reserved-memory

---
 arch/arm64/boot/dts/exynos/exynos9810-starlte.dts | 12 ++++++++++--
 1 file changed, 10 insertions(+), 2 deletions(-)

diff --git a/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts b/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
index ec22a5f374e5..fb63cd32336d 100644
--- a/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
+++ b/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
@@ -25,7 +25,7 @@ chosen {
 
 		framebuffer@cc000000 {
 			compatible = "simple-framebuffer";
-			reg = <0x0 0xcc000000 (1440 * 2960 * 4)>;
+			memory-region = <&cont_splash_mem>;
 			width = <1440>;
 			height = <2960>;
 			stride = <(1440 * 4)>;
@@ -79,7 +79,15 @@ reserved-memory {
 		#size-cells = <1>;
 		ranges;
 
-		framebuffer@cc000000 {
+		ramoops@92000000 {
+			compatible = "ramoops";
+			reg = <0 0x92000000 0x80000>;
+			record-size = <0x20000>;
+			console-size = <0x20000>;
+			pmsg-size = <0x40000>;
+		};
+
+		cont_splash_mem: framebuffer@cc000000 {
 			reg = <0x0 0xcc000000 (1440 * 2960 * 4)>;
 			no-map;
 		};
-- 
2.53.0

