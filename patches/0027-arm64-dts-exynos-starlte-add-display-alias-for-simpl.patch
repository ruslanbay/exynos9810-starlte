From d187700b58e59ed0087d1b7849f0b854247dcca5 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Wed, 11 Mar 2026 14:09:34 +0000
Subject: [PATCH 27/27] arm64: dts: exynos: starlte: add display alias for
 simplefb handoff

---
 arch/arm64/boot/dts/exynos/exynos9810-starlte.dts | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts b/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
index d1d4636d9b97..bd0502779c9f 100644
--- a/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
+++ b/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
@@ -18,12 +18,16 @@ / {
 	compatible = "samsung,starlte", "samsung,exynos9810";
 	chassis-type = "handset";
 
+	aliases {
+		display0 = &framebuffer0;
+	};
+
 	chosen {
 		#address-cells = <2>;
 		#size-cells = <1>;
 		ranges;
 
-		framebuffer@cc000000 {
+		framebuffer0: framebuffer@cc000000 {
 			compatible = "simple-framebuffer";
 			memory-region = <&cont_splash_mem>;
 			width = <1440>;
-- 
2.53.0

