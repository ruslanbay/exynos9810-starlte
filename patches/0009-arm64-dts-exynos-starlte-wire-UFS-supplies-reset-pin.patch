From 39721bd01c248379fa9fa51a223f29fedaeeee83 Mon Sep 17 00:00:00 2001
From: Ruslan Bay <ruslanbey@proton.me>
Date: Mon, 9 Mar 2026 23:18:55 +0100
Subject: [PATCH 09/27] arm64: dts: exynos: starlte: wire UFS
 supplies/reset/pinctrl

---
 .../boot/dts/exynos/exynos9810-starlte.dts    | 20 +++++++++++++++++++
 1 file changed, 20 insertions(+)

diff --git a/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts b/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
index d63192910705..fdaf07f5cd69 100644
--- a/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
+++ b/arch/arm64/boot/dts/exynos/exynos9810-starlte.dts
@@ -84,6 +84,16 @@ framebuffer@cc000000 {
 		};
 	};
 
+	ufs_vcc_reg: regulator-1 {
+		compatible = "regulator-fixed";
+		regulator-name = "ufs-vcc";
+		regulator-min-microvolt = <2950000>;
+		regulator-max-microvolt = <2950000>;
+		regulator-boot-on;
+		enable-active-high;
+		gpio = <&gpf0 2 GPIO_ACTIVE_HIGH>;
+	};
+
 	battery: battery {
 		compatible = "simple-battery";
 		constant-charge-current-max-microamp = <2150000>;
@@ -174,6 +184,16 @@ fuel-gauge@36 {
 	};
 };
 
+&ufs {
+	status = "okay";
+	vcc-supply = <&ufs_vcc_reg>;
+	pinctrl-0 = <&ufs_rst_n &ufs_refclk_out>;
+};
+
+&ufs_phy {
+	status = "okay";
+};
+
 &pinctrl_alive {
 	key_power: key-power-pins {
 		samsung,pins = "gpa2-4";
-- 
2.53.0

