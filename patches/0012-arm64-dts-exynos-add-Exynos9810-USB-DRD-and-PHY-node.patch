From fce0f071873f07d4b1410440cca9ca41035bcfe7 Mon Sep 17 00:00:00 2001
From: Ruslan Bay <ruslanbey@proton.me>
Date: Mon, 9 Mar 2026 23:18:56 +0100
Subject: [PATCH 12/28] arm64: dts: exynos: add Exynos9810 USB DRD and PHY
 nodes

---
 arch/arm64/boot/dts/exynos/exynos9810.dtsi | 28 ++++++++++++++++++++++
 1 file changed, 28 insertions(+)

diff --git a/arch/arm64/boot/dts/exynos/exynos9810.dtsi b/arch/arm64/boot/dts/exynos/exynos9810.dtsi
index 5f232c1ed..6330bdaf4 100644
--- a/arch/arm64/boot/dts/exynos/exynos9810.dtsi
+++ b/arch/arm64/boot/dts/exynos/exynos9810.dtsi
@@ -520,6 +520,34 @@ mmc: mmc@11500000 {
 			#size-cells = <0>;
 			status = "disabled";
 		};
+
+		usbdrd: usb@10c00000 {
+			compatible = "samsung,exynos850-dwusb3";
+			ranges = <0x0 0x10c00000 0x10000>;
+			clocks = <&oscclk>, <&oscclk>;
+			clock-names = "bus_early", "ref";
+			#address-cells = <1>;
+			#size-cells = <1>;
+			status = "disabled";
+
+			usbdrd_dwc3: usb@0 {
+				compatible = "snps,dwc3";
+				reg = <0x0 0x10000>;
+				interrupts = <GIC_SPI 244 IRQ_TYPE_LEVEL_HIGH>;
+				phys = <&usbdrd_phy 0>;
+				phy-names = "usb2-phy";
+			};
+		};
+
+		usbdrd_phy: phy@11100000 {
+			compatible = "samsung,exynos850-usbdrd-phy";
+			reg = <0x11100000 0x100>;
+			clocks = <&oscclk>, <&oscclk>;
+			clock-names = "phy", "ref";
+			samsung,pmu-syscon = <&pmu_system_controller>;
+			#phy-cells = <1>;
+			status = "disabled";
+		};
 	};
 
 	timer {
-- 
2.53.0

